<Page
    x:Class="ATLAS.Pages.ImageAnalysisPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="20" Padding="40">
            <TextBlock Text="Image Analysis" FontSize="32" FontWeight="SemiBold"/>
            <TextBlock Text="Extract and analyze text inside images locally to inspect for potential social engineering scams." TextWrapping="Wrap" Opacity="0.8"/>

            <StackPanel Orientation="Horizontal" Spacing="15">
                <Button x:Name="SelectFileButton" Content="Select Image File" Click="SelectFileButton_Click"/>
                <TextBlock x:Name="SelectedFileNameText" Text="No image selected" VerticalAlignment="Center" Opacity="0.6"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="20">
                <Button x:Name="AnalyzeButton" Content="Analyze Image" IsEnabled="False" Style="{ThemeResource AccentButtonStyle}" Click="AnalyzeButton_Click"/>
                <ProgressRing x:Name="LoadingRing" IsActive="False"/>
            </StackPanel>

            <StackPanel x:Name="ExtractedTextBox" Spacing="10" Visibility="Collapsed" Margin="0,10,0,0">
                <TextBlock Text="Extracted Text Output" FontSize="18" FontWeight="SemiBold"/>
                <Border Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="15">
                    <StackPanel>
                        <TextBlock x:Name="ExtractedText" TextWrapping="Wrap" MaxLines="3" FontSize="14"/>
                        <Button x:Name="ExpandButton" Margin="0,10,0,0" Style="{ThemeResource DefaultButtonStyle}" Click="ExpandExtractedTextButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon x:Name="ExpandExtractedTextIcon" Glyph="&#xE70D;" FontSize="12"/>
                                <TextBlock x:Name="ExpandExtractedTextLabel" Text="Show more"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border x:Name="ResultsBox"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                Padding="24" Margin="0,20,0,0" Visibility="Collapsed">
                <StackPanel Spacing="15">
                    <TextBlock Text="Analysis Result" FontSize="20" FontWeight="SemiBold" />

                    <StackPanel x:Name="StatusPanel" Orientation="Horizontal" Spacing="10" >
                        <FontIcon x:Name="StatusIcon" Glyph="&#xE73E;" FontSize="20"/>
                        <TextBlock x:Name="StatusText" Text="This text appears to be safe." FontSize="18" FontWeight="SemiBold"/>
                    </StackPanel>

                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,1,0,0" Margin="0,10"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Analysis Score:" FontWeight="SemiBold" Margin="0,0,10,0"/>
                        <TextBlock Grid.Column="1" x:Name="ScoreText" Text="-"/>
                    </Grid>
                    <StackPanel>
                        <TextBlock Text="Explanation:" FontWeight="SemiBold"/>
                        <TextBlock x:Name="ExplanationText" TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>